{
  "entities": {
    "Aluno": {
      "title": "Aluno",
      "description": "Dados do aluno da escolinha",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "dataNascimento": { "type": "string" },
        "categoria": { "type": "string" },
        "sub": { "type": "string" },
        "status": { "type": "string" },
        "foto": { "type": "string" },
        "whatsapp": { "type": "string" },
        "matricula": { "type": "string" },
        "dataMatricula": { "type": "string" },
        "numeroCamisa": { "type": "string" },
        "posicao": { "type": "string" }
      },
      "required": ["nome", "sub"]
    },
    "Evento": {
      "title": "Evento",
      "description": "Eventos, jogos e treinos",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "titulo": { "type": "string" },
        "data": { "type": "string" },
        "horario": { "type": "string" },
        "local": { "type": "string" },
        "tipo": { "type": "string" },
        "descricao": { "type": "string" }
      },
      "required": ["titulo", "data"]
    },
    "Professor": {
      "title": "Professor",
      "description": "Professores e comissão técnica",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "cargo": { "type": "string" },
        "foto": { "type": "string" }
      },
      "required": ["nome"]
    },
    "Escalacao": {
      "title": "Escalacao",
      "description": "Escalação de jogadores para um evento",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "eventoId": { "type": "string" },
        "jogadores": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["eventoId"]
    },
    "Presenca": {
      "title": "Presenca",
      "description": "Registro de presença em treinos/eventos",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "eventoId": { "type": "string" },
        "alunoId": { "type": "string" },
        "presente": { "type": "boolean" },
        "data": { "type": "string" }
      },
      "required": ["eventoId", "alunoId"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Configurações do clube",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clubName": { "type": "string" },
        "clubShield": { "type": "string" },
        "colors": {
          "type": "object",
          "properties": {
            "primary": { "type": "string" },
            "secondary": { "type": "string" }
          }
        }
      }
    },
    "SolicitacaoCadastro": {
      "title": "SolicitacaoCadastro",
      "description": "Solicitações de novos alunos via QR Code",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "dataNascimento": { "type": "string" },
        "whatsapp": { "type": "string" },
        "sub": { "type": "string" },
        "status": { "type": "string" },
        "dataSolicitacao": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/alunos/{alunoId}": {
      "schema": "Aluno",
      "description": "Coleção de alunos"
    },
    "/eventos/{eventoId}": {
      "schema": "Evento",
      "description": "Coleção de eventos"
    },
    "/professores/{professorId}": {
      "schema": "Professor",
      "description": "Coleção de professores"
    },
    "/escalacoes/{escalacaoId}": {
      "schema": "Escalacao",
      "description": "Coleção de escalações"
    },
    "/presencas/{presencaId}": {
      "schema": "Presenca",
      "description": "Coleção de presenças"
    },
    "/settings/{settingId}": {
      "schema": "Settings",
      "description": "Configurações do clube"
    },
    "/solicitacoes_cadastro/{solicitacaoId}": {
      "schema": "SolicitacaoCadastro",
      "description": "Solicitações de cadastro"
    }
  }
}
