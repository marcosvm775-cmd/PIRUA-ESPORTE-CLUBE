rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: alunos
    // Document ID: auto-generated or manual
    // Fields: nome, sub, status, dataNascimento, categoria, foto, whatsapp, matricula, dataMatricula, numeroCamisa, posicao
    //
    // Collection: eventos
    // Document ID: auto-generated
    // Fields: titulo, data, horario, local, tipo, descricao
    //
    // Collection: professores
    // Document ID: auto-generated
    // Fields: nome, cargo, foto
    //
    // Collection: escalacoes
    // Document ID: auto-generated
    // Fields: eventoId, jogadores (array)
    //
    // Collection: presencas
    // Document ID: auto-generated
    // Fields: eventoId, alunoId, presente, data
    //
    // Collection: settings
    // Document ID: 'main' or auto-generated
    // Fields: clubName, clubShield, colors (map)
    //
    // Collection: solicitacoes_cadastro
    // Document ID: auto-generated
    // Fields: nome, dataNascimento, whatsapp, sub, status, dataSolicitacao
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "marcos.vm775@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    function hasOnlyAllowedFields(data, allowedFields) {
      return data.keys().hasOnly(allowedFields);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /alunos/{alunoId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /eventos/{eventoId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /professores/{professorId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /escalacoes/{escalacaoId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /presencas/{presencaId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /solicitacoes_cadastro/{solicitacaoId} {
      allow read: if isAuthenticated();
      allow create: if true; // Allow anyone to request registration
      allow update, delete: if isAdmin();
    }
  }
}
